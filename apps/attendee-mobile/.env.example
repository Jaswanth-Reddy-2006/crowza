# Firebase Configuration
# Get these values from your Firebase Project Settings in Firebase Console
# https://console.firebase.google.com/

# Your Firebase API Key (public)
# Found in: Project Settings → Web API Key
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Firebase Auth Domain
# Format: yourproject.firebaseapp.com
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=crowza.firebaseapp.com

# Your Firebase Project ID
# Found in: Project Settings → Project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=crowza

# Your Firebase Storage Bucket
# Format: yourproject.appspot.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=crowza.appspot.com

# Firebase Messaging Sender ID
# Found in: Project Settings → Cloud Messaging → Sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=626426589835

# Your Firebase App ID
# Found in: Project Settings → App ID
EXPO_PUBLIC_FIREBASE_APP_ID=1:626426589835:web:a553b4464bf7b5874a5a8e

# ============================================
# API Configuration
# ============================================

# Backend API Base URL
EXPO_PUBLIC_API_BASE_URL=https://api.crowza.com

# API Timeout (milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# ============================================
# Google Maps Configuration
# ============================================

# Google Maps API Key
# Get from: Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# App Configuration
# ============================================

# Environment: development, staging, production
NODE_ENV=development

# App Debug Mode (true/false)
# Set to false for production builds
DEBUG=true

# ============================================
# Features & Flags
# ============================================

# Enable Location Tracking
EXPO_PUBLIC_LOCATION_TRACKING_ENABLED=true

# Enable Indoor Navigation
EXPO_PUBLIC_INDOOR_NAVIGATION_ENABLED=true

# Enable Heat Map
EXPO_PUBLIC_HEAT_MAP_ENABLED=true

# Enable Audit Logging
EXPO_PUBLIC_AUDIT_LOGGING_ENABLED=true

# ============================================
# Security Configuration
# ============================================

# Rate Limiting: Max requests per minute per user
EXPO_PUBLIC_RATE_LIMIT_PER_MINUTE=100

# Encryption Key (optional, for additional security)
# Generate with: openssl rand -base64 32
EXPO_PUBLIC_ENCRYPTION_KEY=

# ============================================
# Setup Instructions
# ============================================

# 1. Copy this file to .env.local (or .env.development.local for specific env)
#    cp .env.example .env.local
#
# 2. Fill in your actual Firebase values from Firebase Console
#
# 3. For development, you can use test/demo values
#    For production, use secure, unique values
#
# 4. DO NOT commit .env.local to version control
#    Add to .gitignore: .env.local, .env.*.local
#
# 5. Restart your development server after making changes
#    npx expo start --clear
